# Copie este arquivo para ".env" (nunca commitado - já coberto pelo .gitignore
# da raiz do repositório) e preencha com valores reais antes de rodar
# `docker compose up` (05_DEVOPS_E_SEGURANCA.md §A.3/§D).

DATABASE_PATH=/data/irontrack.db

# Mínimo 256 bits de entropia, gerado por gerador criptográfico seguro -
# nunca uma string memorável (05_DEVOPS_E_SEGURANCA.md §D).
JWT_SECRET_KEY=changeme-generate-a-cryptographically-random-256-bit-secret
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000

# Em produção: um único valor, nunca "*" (05_DEVOPS_E_SEGURANCA.md §E.3).
CORS_ALLOWED_ORIGINS=https://app.irontrack.com

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=changeme
SMTP_PASSWORD=changeme
MAIL_FROM_ADDRESS=no-reply@irontrack.com
